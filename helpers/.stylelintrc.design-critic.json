{
  "$schema": "https://json.schemastore.org/stylelintrc.json",
  "plugins": [
    "stylelint-declaration-strict-value"
  ],
  "rules": {
    "scale-unlimited/declaration-strict-value": [
      [
        "color",
        "background-color",
        "border-color",
        "fill",
        "stroke",
        "/^padding/",
        "/^margin/",
        "/^gap/",
        "font-size",
        "font-family",
        "border-radius",
        "box-shadow"
      ],
      {
        "ignoreValues": [
          "transparent",
          "inherit",
          "initial",
          "unset",
          "currentColor",
          "none",
          "0",
          "0px",
          "auto",
          "100%",
          "50%"
        ],
        "ignoreFunctions": true,
        "disableFix": true,
        "expandShorthand": true,
        "message": "Design-System-Verstoss: '${value}' fuer '${property}' sollte eine Variable ($var) oder var(--var) sein"
      }
    ]
  }
}
